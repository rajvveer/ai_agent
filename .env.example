# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/business_copilot
DB_MAX_CONNECTIONS=20

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── JWT Auth ──────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OTP / Email ───────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
OTP_FROM_EMAIL=noreply@yourdomain.com

# ── OTP / Phone (Twilio) ─────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── WhatsApp (360dialog) ─────────────────────────────
WHATSAPP_PROVIDER=360dialog
WHATSAPP_API_KEY=your-360dialog-api-key
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-verify-token

# ── LLM (Primary: Kimi K2.5) ─────────────────────────
LLM_PROVIDER=kimi
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k

# ── LLM (Local: Ollama) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ── LLM (Future: Anthropic) ──────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Vector Store ──────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key

# ── File Storage ──────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=business-copilot

# ── Observability ────────────────────────────────────
SENTRY_DSN=
LANGSMITH_API_KEY=

# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
